PORT=5555
NODE_ENV=development

# Protections disabled for personal/local use.
DISABLE_AUTH=true
DISABLE_RATE_LIMIT=true

# Request timeout (ms) when scraping PelisPlus.
REQUEST_TIMEOUT_MS=15000

# Download engine settings.
DOWNLOADS_DIR=downloads
DOWNLOAD_REQUEST_TIMEOUT_MS=120000

# Use this when PelisPlus changes domain.
DEFAULT_PELISPLUS_DOMAIN=www.pelisplushd.la

# Debug download resolvers (true/false).
DEBUG_DOWNLOAD=false
